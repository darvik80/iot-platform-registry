FROM rabbitmq:management

ADD rabbitmq/rabbitmq-init.sh /rabbitmq-init.sh
ADD rabbitmq/rabbitmq.conf /etc/rabbitmq/rabbitmq.conf
ADD rabbitmq/cert /etc/rabbitmq/cert

ARG RABBITMQ_ADMIN_USER
ENV RABBITMQ_ADMIN_USER ${RABBITMQ_ADMIN_USER}

ARG RABBITMQ_ADMIN_PASSWORD
ENV RABBITMQ_ADMIN_PASSWORD ${RABBITMQ_ADMIN_PASSWORD}

ARG RABBITMQ_API_USER
ENV RABBITMQ_API_USER ${RABBITMQ_API_USER}

ARG RABBITMQ_API_PASSWORD
ENV RABBITMQ_API_PASSWORD ${RABBITMQ_API_PASSWORD}

ARG RABBITMQ_MQTT_USER
ENV RABBITMQ_MQTT_USER ${RABBITMQ_MQTT_USER}

ARG RABBITMQ_MQTT_PASSWORD
ENV RABBITMQ_MQTT_PASSWORD ${RABBITMQ_MQTT_PASSWORD}
ENV RABBITMQ_HIPE_COMPILE 1

RUN rabbitmq-plugins enable --offline rabbitmq_management && \
    rabbitmq-plugins enable --offline rabbitmq_mqtt

EXPOSE 1883 8883 5671 5672 15671 15672 15674 15675 25672 61613

CMD ["/bin/sh", "/rabbitmq-init.sh"]